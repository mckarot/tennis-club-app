# Firebase Configuration
# Replace placeholder values with your actual Firebase project credentials

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=tennis-francois

# Firebase API Key
# Get this from Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=your-api-key-here

# Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=tennis-francois.firebaseapp.com

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=tennis-francois.appspot.com

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here

# Firebase App ID
VITE_FIREBASE_APP_ID=your-app-id-here

# Emulator Configuration (for local development)
# These are used by the Firebase SDK to connect to local emulators
VITE_FIREBASE_EMULATOR_HOST=localhost
VITE_FIRESTORE_EMULATOR_PORT=8080
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIREBASE_EMULATOR_UI_PORT=4000
